---
import { procesoData } from "../data/proceso";
---

<section id="proceso" class="proceso">
  <div class="proceso__container">
    <div class="proceso__header reveal">
      <h2 class="proceso__title">{procesoData.header.title}</h2>
      <p class="proceso__subtitle">{procesoData.header.subtitle}</p>
    </div>

    <div class="proceso__grid">
      {
        procesoData.steps.map((step) => (
          <div class={`proceso__card reveal ${step.delay || ""}`}>
            <div class="proceso__num">{step.num}</div>
            <h3 class="proceso__step-title">{step.title}</h3>
            <p class="proceso__description">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .proceso {
    padding: 6rem 3rem;

    &__container {
      max-width: 80rem;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-bottom: 2.5rem;
      border-bottom: 0.5px solid var(--pill-border);
      margin-bottom: 3.75rem;

      @media (max-width: 64rem) {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }
    }

    &__title {
      font-size: clamp(2.25rem, 4vw, 3.375rem);
      font-weight: 400;
      letter-spacing: -0.015em;
      color: var(--ink);
    }

    &__subtitle {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-mid);
      max-width: 20rem;
      text-align: right;
      line-height: 1.7;

      @media (max-width: 64rem) {
        text-align: left;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;

      @media (max-width: 64rem) {
        grid-template-columns: 1fr;
      }
    }

    &__card {
      padding: 2.25rem;
      background: var(--white);
      border-radius: 1.25rem;
      border: 0.5px solid var(--pill-border);
      transition:
        transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.4s;

      &:hover {
        transform: translateY(-0.35rem);
        box-shadow: 0 1.25rem 3rem rgba(26, 25, 22, 0.07);
      }

      @media (hover: none), (pointer: coarse) {
        box-shadow: 0 1.25rem 3rem rgba(26, 25, 22, 0.07);
      }
    }

    &__num {
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      margin-bottom: 1.25rem;
      color: var(--sage);
    }

    &__step-title {
      font-size: 1.375rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }

    &__description {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.7;
    }
  }
</style>
