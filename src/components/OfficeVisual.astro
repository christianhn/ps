---
import { Image } from "astro:assets";
import ofiImg from "../assets/img/ofi-ia.png";
---

<section class="office-reveal" id="office-reveal">
  <div class="office-reveal__sticky">
    <div class="office-reveal__container">
      <div class="office-reveal__wrapper">
        <Image
          src={ofiImg}
          alt="Consulta de Mario Catena"
          class="office-reveal__image"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<script>
  function initStickyReveal() {
    const track = document.getElementById("office-reveal");
    const container = track?.querySelector(
      ".office-reveal__container",
    ) as HTMLElement;
    const wrapper = track?.querySelector(
      ".office-reveal__wrapper",
    ) as HTMLElement;
    const image = track?.querySelector(".office-reveal__image") as HTMLElement;

    if (!track || !container || !wrapper || !image) return;

    const updateEffect = () => {
      const rect = track.getBoundingClientRect();
      const winH = window.innerHeight;
      const isMobile = window.innerWidth <= 768;

      const totalScroll = track.offsetHeight - winH;
      const currentScroll = -rect.top;
      let progress = Math.min(Math.max(currentScroll / totalScroll, 0), 1);

      // Expansion phase (0 to 0.7)
      const expandProgress = Math.min(progress / 0.7, 1);

      // Calculate Width
      const startWidth = isMobile ? 90 : 80;
      const currentWidth = startWidth + (100 - startWidth) * expandProgress;
      container.style.width = `${currentWidth}vw`;
      container.style.maxWidth = "100vw";

      // Calculate Height
      // On mobile, we avoid 100vh to maintain the horizontal feel of the original photo
      const startHeight = isMobile ? 45 : 70;
      const endHeight = isMobile ? 60 : 100;
      const currentHeight =
        startHeight + (endHeight - startHeight) * expandProgress;
      container.style.height = `${currentHeight}vh`;

      // Calculate Border Radius
      const startRadius = isMobile ? 20 : 24;
      const currentRadius = startRadius * (1 - expandProgress);
      container.style.borderRadius = `${currentRadius}px`;

      // Movement and Image Scaling
      const translateY = expandProgress * -30;
      image.style.transform = `scale(${isMobile ? 1.1 : 1.25} - ${expandProgress * 0.1}) translateY(${translateY}px)`;
    };

    window.addEventListener("scroll", updateEffect, { passive: true });
    updateEffect();
  }

  document.addEventListener("astro:page-load", initStickyReveal);
</script>

<style lang="scss">
  .office-reveal {
    height: 200vh; // Slightly shorter track on mobile for better pace
    position: relative;
    background: var(--cream-mid);

    @media (min-width: 48rem) {
      height: 250vh;
    }

    &__sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    &__container {
      width: 80vw;
      height: 70vh;
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
      will-change: width, height, border-radius;

      @media (max-width: 48rem) {
        width: 90vw;
        height: 45vh; // More horizontal start
        border-radius: 20px;
      }
    }

    &__wrapper {
      width: 100%;
      height: 100%;
      position: relative;
    }

    &__image {
      width: 100%;
      height: 115%;
      position: absolute;
      top: -7.5%;
      left: 0;
      object-fit: cover;
      object-position: 70% center; // Focus more on the desk/chair (right side)
      display: block;
      will-change: transform;

      @media (max-width: 48rem) {
        object-position: 40% center;
      }
    }
  }
</style>
