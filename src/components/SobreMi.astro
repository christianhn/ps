---
import { Image } from "astro:assets";
import { sobreMiData as data } from "../data/sobreMi";
---

<section id="sobre-mi" class="sobre">
  <!-- Statement -->
  <div class="sobre__statement reveal">
    <h2 class="sobre__statement-title" set:html={data.statement.title} />
  </div>

  <!-- Bio Section -->
  <div class="sobre__split sobre__split--bio">
    <div class="sobre__img-col">
      <div class="sobre__img-wrapper">
        <div class="sobre__img-inner">
          <Image
            src={data.bio.image}
            alt={data.bio.alt}
            class="sobre__portrait"
          />
        </div>
      </div>
      <p class="sobre__collegiate">{data.formacion.footer}</p>
    </div>

    <div class="sobre__content reveal">
      <p class="sobre__eyebrow">{data.bio.eyebrow}</p>
      <h2 class="sobre__title" set:html={data.bio.title} />
      {
        data.bio.paragraphs.map((text) => (
          <p
            class="sobre__body"
            set:html={text.replace(
              "psicólogo general sanitario",
              "<span class='text-highlight'>psicólogo general sanitario</span>",
            )}
          />
        ))
      }
    </div>
  </div>

  <!-- Formacion -->
  <article class="sobre__experience">
    <header class="sobre__experience-header reveal">
      <p class="sobre__eyebrow">{data.formacion.eyebrow}</p>
      <h2
        class="sobre__title sobre__title--experience"
        set:html={data.formacion.title}
      />
    </header>

    <div class="sobre__experience-grid reveal">
      {
        data.formacion.cards.map((card) => (
          <div class="sobre__experience-card">
            <p class="sobre__eyebrow sobre__eyebrow--institution">
              {card.institution}
            </p>
            <h3 class="sobre__card-title">{card.title}</h3>
            <p class="sobre__card-description">{card.description}</p>
          </div>
        ))
      }

      <!-- ISIAS -->
      <div class="sobre__experience-card sobre__experience-card--full">
        <p class="sobre__eyebrow sobre__eyebrow--institution">
          {data.formacion.isias.institution}
        </p>
        <ul class="sobre__list-vertical">
          {
            data.formacion.isias.items.map((item) => (
              <li class="sobre__list-item">{item}</li>
            ))
          }
        </ul>
      </div>

      <!-- AEPS -->
      <div class="sobre__experience-card sobre__experience-card--full">
        <p class="sobre__eyebrow sobre__eyebrow--institution">
          {data.formacion.aeps.institution}
        </p>
        <ul class="sobre__list-grid">
          {data.formacion.aeps.list.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <!-- Otras -->
      <div class="sobre__experience-card sobre__experience-card--full">
        <p class="sobre__eyebrow sobre__eyebrow--institution">
          {data.formacion.otras.institution}
        </p>
        <div class="sobre__otras-grid">
          {
            data.formacion.otras.items.map((item) => (
              <div class="sobre__subcard">
                <h3 class="sobre__subcard-title">{item.title}</h3>
                <p class="sobre__subcard-description">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </article>
</section>

<style lang="scss">
  .sobre {
    &__container {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem;
    }

    // --- Typography Bases ---
    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-light);

      &--institution {
        margin-bottom: 0.5rem;
        color: var(--sage);
        font-size: 0.625rem;
        opacity: 0.8;
      }
    }

    &__title {
      font-family: inherit;
      font-size: clamp(1.875rem, 3.2vw, 2.875rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: 1rem 0 1.25rem;

      :global(em) {
        font-style: italic;
        color: var(--sage);
      }
      &--experience {
        margin-top: 0.25rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity: 0.7; // Subtler heading
      }
    }

    :global(.text-highlight) {
      color: var(--sage);
      font-weight: 500;
    }

    &__body {
      font-size: 1.0625rem; // Increased for closeness
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.85;
      & + & {
        margin-top: 0.875rem;
      }
    }

    &__collegiate {
      font-size: 0.9rem;
      color: var(--ink-light);
      margin-top: 1rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      opacity: 0.7;
    }

    &__img-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }

    // --- Layout Patterns ---
    &__statement {
      padding: 0 3rem 5rem;
      text-align: center;
      max-width: 80rem;
      margin: 0 auto;

      &-title {
        @extend .sobre__title;
        font-size: clamp(2.75rem, 6.5vw, 6rem);
        line-height: 1;
        letter-spacing: -0.025em;
        max-width: 65.625rem;
        margin: 0 auto;
      }
    }

    &__split {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem 6rem;
      display: grid;
      grid-template-columns: 50% 1fr;
      gap: 3.75rem;
      align-items: center;
      justify-items: center;

      &--bio {
        padding-bottom: 5rem;
      }

      @media (max-width: 75rem) {
        gap: 2.5rem;
        padding-inline: 2rem;
      }

      @media (max-width: 64rem) {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
        justify-items: center;
      }
    }

    &__img-wrapper {
      border-radius: var(--radius-card);
      overflow: hidden;
      aspect-ratio: 4 / 5;
      position: relative;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      background: var(--cream-mid); // Neutral placeholder
      max-width: 30rem;
      width: 100%;

      @media (max-width: 75rem) {
        max-width: 25rem;
      }

      @media (max-width: 64rem) {
        max-width: 22rem;
        margin: 0 auto;
      }

      @media (max-width: 42.5rem) {
        max-width: 100%;
        max-height: 30rem;
      }

      &--online {
        background: var(--ash);
      }
    }

    &__img-inner,
    &__portrait {
      width: 100%;
      height: 100%;
    }
    &__portrait {
      object-fit: cover;
      object-position: 50% 35%;
    }

    &__content {
      padding: 1rem 0;
    }

    // --- Experience Section ---
    &__experience {
      padding: 2.5rem 3rem 6.25rem;
      max-width: 80rem;
      margin: 0 auto;

      &-header {
        text-align: center;
        margin-bottom: 3rem;
      }
      &-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem 3.5rem;
        text-align: left;

        @media (max-width: 75rem) {
          gap: 2.5rem 3rem;
        }

        @media (max-width: 50rem) {
          grid-template-columns: 1fr;
        }
      }
      &-card {
        padding-top: 1rem;
        border-top: 1px solid #c4ccbe;
        &--full {
          grid-column: 1 / -1;
        }
      }
      &-footer {
        margin-top: 5rem;
        text-align: center;
        &-text {
          font-size: 0.875rem;
          font-style: italic;
          color: var(--sage);
          line-height: 1.6;
        }
      }
    }

    &__card-title,
    &__list-title,
    &__subcard-title {
      font-size: 1.1rem;
      font-weight: 500;
      line-height: 1.3;
      letter-spacing: -0.01em;
      margin: 0.5rem 0 0.5rem;
      color: var(--ink);
    }

    &__list-title {
      font-weight: 400; // Less prominent for experts
      font-size: 1.05rem;
      color: var(--ink-mid);
    }

    &__card-description,
    &__list-item,
    &__subcard-description {
      font-size: 0.875rem;
      color: var(--ink-light);
      line-height: 1.6;
      font-weight: 300;
    }

    &__list-item {
      position: relative;
      &:first-child {
        margin-top: 0.75rem;
      }
    }

    &__list-vertical,
    &__list-grid,
    &__otras-grid {
      list-style: none;
      display: grid;
    }
    &__list-vertical {
      gap: 0.75rem;
    }
    &__otras-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 18.75rem), 1fr));
      gap: 2.25rem 3rem;
    }
    &__list-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 16.25rem), 1fr));
      gap: 1rem 2rem;
      li {
        font-size: 0.95rem;
        color: var(--ink-mid);
        font-weight: 300;
        position: relative;
        line-height: 1.85;
      }
    }

    &__online-link {
      margin-top: 1.75rem;
      display: inline-flex;
    }

    // --- Global Media Queries ---
    @media (max-width: 64rem) {
      &__statement,
      &__split,
      &__experience {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }
      &__split {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        &--reverse {
          .sobre__img-wrapper {
            order: 0;
          }
          .sobre__content {
            order: 0;
          }
        }
      }
      &__img-wrapper {
        aspect-ratio: 16/19;
      }
    }

    @media (max-width: 50rem) {
      &__experience-grid {
        grid-template-columns: 1fr;
      }
    }
  }
</style>
