---
import { Image } from "astro:assets";
import { sobreMiData as data } from "../data/sobreMi";
---

<section class="online-section reveal">
  <div class="online-container">
    <div class="online__split online__split--reverse">
      <div class="online__content">
        <p class="online__eyebrow">{data.online.eyebrow}</p>
        <h2 class="online__title" set:html={data.online.title} />
        {data.online.paragraphs.map((text) => <p class="online__body">{text}</p>)}
        <a href={data.online.cta.href} class="text-link online__cta">
          {data.online.cta.text} →
        </a>
      </div>

      <div class="online__img-wrapper">
        <div class="online__img-inner">
          <Image
            src={data.online.image}
            alt={data.online.alt}
            class="online__portrait"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .online-section {
    padding: 6rem 0;
    // Removed local background to inherit from page (like before)
  }

  .online-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0; // Padding is handled by the split
  }

  .online {
    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-light);
    }

    &__title {
      font-family: inherit;
      font-size: clamp(1.875rem, 3.2vw, 2.875rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: 1rem 0 1.25rem;

      :global(em) {
        font-style: italic;
        color: var(--sage);
      }
    }

    &__body {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.85;
      & + & {
        margin-top: 0.875rem;
      }
    }

    &__split {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem 6rem;
      display: grid;
      grid-template-columns: 50% 1fr;
      gap: 3.75rem;
      align-items: center;
      justify-items: center;

      &--reverse {
        .online__img-wrapper {
          order: 2;
        }
        .online__content {
          order: 1;
        }
      }

      @media (max-width: 64rem) {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding-left: 1.5rem;
        padding-right: 1.5rem;

        &--reverse {
          .online__img-wrapper {
            order: 0;
          }
          .online__content {
            order: 0;
          }
        }
      }
    }

    &__img-wrapper {
      border-radius: var(--radius-card);
      overflow: hidden;
      aspect-ratio: 4/5;
      position: relative;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      background: linear-gradient(
        145deg,
        #b4c4c8 0%,
        #c8d8dc 50%,
        #a4b4b8 100%
      );
      max-width: 30vw;

      @media (max-width: 64rem) {
        max-width: 40vw;
        aspect-ratio: 16/19;
      }

      @media (max-width: 42.5rem) {
        max-width: 100%;
      }
    }

    &__img-inner,
    &__portrait {
      width: 100%;
      height: 100%;
    }

    &__portrait {
      object-fit: cover;
    }


    &__content {
      padding: 1rem 0;
    }

    &__cta {
      margin-top: 1.75rem;
      display: inline-flex;
    }
  }
</style>
