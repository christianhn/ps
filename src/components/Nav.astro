---
import { navData } from "../data/nav";
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav class="nav" id="main-nav">
  <div class="nav__inner">
    <div class="nav__header">
      <a href={`${baseUrl}/`} class="nav__logo">{navData.logo}</a>
      <button
        class="nav__toggle mobile-menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="nav-list"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line class="line-top" x1="4" y1="8" x2="20" y2="8"></line>
          <line class="line-bot" x1="4" y1="16" x2="20" y2="16"></line>
        </svg>
      </button>
    </div>

    <ul class="nav__list" id="nav-list">
      {
        navData.links.map((link) => (
          <li class="nav__item">
            <a
              href={`${baseUrl}${link.href}`}
              class:list={[
                "nav__link",
                { "btn-dark": link.variant === "primary" },
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const setupNav = () => {
    const navInner = document.querySelector(".nav__inner") as HTMLElement;
    const navList = document.querySelector(".nav__list") as HTMLElement;
    const menuBtn = document.querySelector(
      ".mobile-menu-btn",
    ) as HTMLButtonElement;

    if (!navInner || !menuBtn || !navList) return;

    // 1. Theme Switcher (Adapts to dark backgrounds)
    // We target refactored classes and common dark containers
    const darkSections = document.querySelectorAll(
      ".ayuda, .contacto__card, .stats-section",
    );

    const updateTheme = () => {
      const navRect = navInner.getBoundingClientRect();
      const navCenterY = navRect.top + navRect.height / 2;

      let isOverDark = false;
      for (const section of darkSections) {
        const rect = section.getBoundingClientRect();
        // Check if nav center is within section vertical bounds
        if (navCenterY >= rect.top && navCenterY <= rect.bottom) {
          isOverDark = true;
          break;
        }
      }

      navInner.classList.toggle("nav__inner--dark", isOverDark);
    };

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateTheme();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    updateTheme(); // Initial check

    // 2. Mobile Menu Toggle
    const toggleMenu = () => {
      const isOpen = navList.classList.toggle("nav__list--open");
      menuBtn.classList.toggle("nav__toggle--open", isOpen);
      menuBtn.setAttribute("aria-expanded", isOpen.toString());
    };

    menuBtn.addEventListener("click", toggleMenu);

    // Close menu when clicking links
    navList.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        navList.classList.remove("nav__list--open");
        menuBtn.classList.remove("nav__toggle--open");
        menuBtn.setAttribute("aria-expanded", "false");
      });
    });
  };

  // Run on first load and on every page navigation (View Transitions)
  document.addEventListener("astro:page-load", setupNav);
</script>

<style lang="scss">
  .nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: calc(100% - 3rem);
    max-width: 80rem;

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(249, 247, 243, 0.85);
      backdrop-filter: blur(1.125rem);
      -webkit-backdrop-filter: blur(1.125rem);
      border: 0.5px solid var(--pill-border);
      border-radius: 3.125rem;
      padding: 0.625rem 0.75rem 0.625rem 1.75rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);

      // Normal mode (Light Nav)
      .btn-dark {
        background: var(--ink);
        color: var(--cream);
        padding: 0.625rem 1.25rem;
        font-size: 0.75rem;
        border-radius: 2rem;

        &:hover {
          background: var(--ink-mid);
          color: var(--white);
        }
      }

      &--dark {
        background: rgba(26, 25, 22, 0.85);
        border-color: rgba(255, 255, 255, 0.15);

        .nav__logo {
          color: var(--white);
        }
        .nav__link {
          color: var(--white-60);
          &:hover {
            color: var(--white);
          }
        }
        .nav__toggle {
          color: var(--white);
        }

        // Button in Dark Nav
        .btn-dark {
          background: var(--white);
          color: var(--ink);

          &:hover {
            background: var(--cream);
            color: var(--ink);
          }
        }
      }

      @media (max-width: 50rem) {
        padding: 0.75rem;
        flex-direction: column;
        align-items: stretch;
        border-radius: 1.5rem;
      }
    }

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &__logo {
      font-family: "DM Serif Display", serif;
      font-size: 1.0625rem;
      font-weight: 400;
      color: var(--ink);
      text-decoration: none;
      white-space: nowrap;
      transition: color 0.4s ease;

      &:hover {
        opacity: 0.8;
      }
    }

    &__list {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      list-style: none;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);

      @media (max-width: 50rem) {
        flex-direction: column;
        gap: 1.25rem;
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        pointer-events: none;
        padding: 0;

        &--open {
          max-height: 25rem;
          opacity: 1;
          pointer-events: auto;
          padding: 1.5rem 0.5rem 0.75rem;
        }
      }
    }

    &__link {
      font-size: 0.8125rem;
      font-weight: 400;
      color: var(--ink-mid);
      text-decoration: none;
      transition: color 0.4s ease;

      &:hover {
        color: var(--ink);
      }
    }

    &__toggle {
      display: none;
      background: none;
      border: none;
      color: var(--ink);
      cursor: pointer;
      padding: 0.5rem;
      transition: color 0.3s;

      @media (max-width: 50rem) {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .line-top,
      .line-bot {
        transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .line-top {
        transform-origin: 12px 8px;
      }
      .line-bot {
        transform-origin: 12px 16px;
      }

      &--open {
        .line-top {
          transform: translateY(4px) rotate(45deg);
        }
        .line-bot {
          transform: translateY(-4px) rotate(-45deg);
        }
      }
    }
  }
</style>
