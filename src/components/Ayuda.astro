---
import { Image } from "astro:assets";
import { ayudaData as services } from "../data/ayuda";
---

<section id="ayuda" class="ayuda">
  <div class="ayuda__container">
    <header class="ayuda__header reveal">
      <p class="ayuda__eyebrow text-gradient-textured">Cómo puedo ayudarte</p>
      <h2 class="ayuda__title">
        El trabajo psicológico,<br /><em class="text-gradient-textured"
          >un camino hacia ti.</em
        >
      </h2>
      <p class="ayuda__subtitle">
        Como individuo atravesando dificultades personales o como pareja
        afrontando momentos complejos, buscar ayuda es un paso adelante.
      </p>
    </header>

    <ayuda-tabs class="ayuda-tabs">
      <div
        class="ayuda-tabs__list"
        role="tablist"
        aria-label="Servicios de terapia"
      >
        {
          services.map((service, index) => (
            <button
              class={`ayuda-tabs__button ${index === 0 ? "is-active" : ""}`}
              data-tab={service.id}
              id={`tab-${service.id}`}
              role="tab"
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${service.id}`}
              tabindex={index === 0 ? 0 : -1}
            >
              {service.label}
            </button>
          ))
        }
      </div>

      <div class="ayuda-tabs__panels">
        {
          services.map((service, index) => (
            <div
              id={`panel-${service.id}`}
              class={`ayuda-panel ${index === 0 ? "is-active" : ""}`}
              data-panel={service.id}
              role="tabpanel"
              aria-labelledby={`tab-${service.id}`}
              hidden={index !== 0}
            >
              <div class="ayuda-panel__image">
                <Image src={service.image} alt={service.title} />
              </div>
              <div class="ayuda-panel__content">
                <p class="ayuda-panel__intro">{service.intro}</p>
                <ul class="ayuda-panel__list">
                  {service.list.map((item) => (
                    <li class="ayuda-panel__item">{item}</li>
                  ))}
                </ul>
                <div class="ayuda-panel__actions">
                  <a
                    href="#contacto"
                    data-service={service.svc || service.id}
                    class="btn-dark"
                  >
                    Pedir cita
                  </a>
                  <a
                    href="#contacto"
                    data-service={service.svc || service.id}
                    class="btn-ghost ayuda-panel__ghost-btn"
                  >
                    Sesión online disponible
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </ayuda-tabs>
  </div>
</section>

<style lang="scss">
  .ayuda {
    background: var(--ash);
    padding: 6rem 0;

    &__container {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem;
    }

    &__header {
      text-align: center;
      margin-bottom: 4.5rem;
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      @extend .text-gradient-textured !optional;
      color: var(--sage);
    }

    &__title {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      font-size: clamp(2.25rem, 4.5vw, 3.75rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-top: 1rem;
      line-height: 1.1;

      em {
        font-style: italic;
        @extend .text-gradient-textured !optional;
      }
    }

    &__subtitle {
      font-size: 0.9375rem;
      font-weight: 300;
      color: var(--ink-mid);
      margin-top: 1rem;
      line-height: 1.7;
      max-width: 31.25rem;
      margin-inline: auto;
    }
  }

  .ayuda-tabs {
    &__list {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-bottom: 3.25rem;
    }

    &__button {
      padding: 0.625rem 1.5rem;
      border-radius: 3.125rem;
      font-size: 0.875rem;
      font-weight: 400;
      background: transparent;
      color: var(--ink-light);
      border: 0.5px solid var(--pill-border);
      transition: all 0.25s ease;

      &:hover:not(.is-active) {
        color: var(--ink);
        border-color: rgba(21, 21, 21, 0.2);
        background: rgba(21, 21, 21, 0.03);
      }

      &.is-active {
        background: var(--ink);
        color: var(--white);
        border-color: var(--ink);
        font-weight: 500;
      }
    }
  }

  .ayuda-panel {
    display: none;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;

    &.is-active {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      opacity: 1;
      transform: translateY(0);
    }

    &__image {
      border-radius: var(--radius-card);
      overflow: hidden;
      aspect-ratio: 4 / 5;
      background: var(--cream-mid);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 3rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);

      @media (max-width: 64rem) {
        margin: 1rem 8rem;
      }

      @media (max-width: 42.5rem) {
        margin: 0;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 1.25rem;
        opacity: 0.85;
      }
    }

    &__content {
      padding: 0.5rem 0;
    }

    &__intro {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      font-size: clamp(1.125rem, 2vw, 1.5rem);
      font-style: italic;
      font-weight: 400;
      color: var(--ink-mid);
      line-height: 1.5;
      margin-bottom: 2rem;
      padding-bottom: 1.75rem;
      border-bottom: 0.5px solid var(--pill-border);
    }

    &__list {
      list-style: none;
      padding: 0;
    }

    &__item {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-light);
      line-height: 1.7;
      padding: 0.875rem 0;
      border-bottom: 0.5px solid rgba(21, 21, 21, 0.05);
      display: flex;
      gap: 0.875rem;
      align-items: flex-start;

      &::before {
        content: "";
        width: 0.3125rem;
        height: 0.3125rem;
        border-radius: 50%;
        background: var(--sage-light);
        flex-shrink: 0;
        margin-top: 0.5rem;
      }
    }

    &__actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    &__ghost-btn {
      color: var(--ink-light);
      border-color: var(--pill-border);
    }
  }

  @media (max-width: 64rem) {
    .ayuda {
      &__container {
        padding: 0 1.5rem;
      }
    }

    .ayuda-panel.is-active {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ayuda-panel__image {
      aspect-ratio: 16 / 10;
    }

    .ayuda-tabs__list {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  class AyudaTabs extends HTMLElement {
    private tabs: HTMLButtonElement[];
    private panels: HTMLElement[];

    constructor() {
      super();
      this.tabs = Array.from(this.querySelectorAll('[role="tab"]'));
      this.panels = Array.from(this.querySelectorAll('[role="tabpanel"]'));
    }

    connectedCallback() {
      this.tabs.forEach((tab) => {
        tab.addEventListener("click", () => this.switchTab(tab));
        tab.addEventListener("keydown", (e) => this.handleKeyDown(e));
      });
    }

    private switchTab(newTab: HTMLButtonElement) {
      const targetPanelId = newTab.getAttribute("aria-controls");

      this.tabs.forEach((t) => {
        t.classList.remove("is-active");
        t.setAttribute("aria-selected", "false");
        t.setAttribute("tabindex", "-1");
      });

      this.panels.forEach((p) => {
        p.classList.remove("is-active");
        p.hidden = true;
      });

      newTab.classList.add("is-active");
      newTab.setAttribute("aria-selected", "true");
      newTab.setAttribute("tabindex", "0");
      newTab.focus();

      const panel = this.querySelector(`#${targetPanelId}`) as HTMLElement;
      if (panel) {
        panel.hidden = false;
        requestAnimationFrame(() => {
          panel.classList.add("is-active");
        });
      }
    }

    private handleKeyDown(e: KeyboardEvent) {
      const index = this.tabs.indexOf(e.currentTarget as HTMLButtonElement);
      let newIndex: number | null = null;

      if (e.key === "ArrowRight") {
        newIndex = (index + 1) % this.tabs.length;
      } else if (e.key === "ArrowLeft") {
        newIndex = (index - 1 + this.tabs.length) % this.tabs.length;
      } else if (e.key === "Home") {
        newIndex = 0;
      } else if (e.key === "End") {
        newIndex = this.tabs.length - 1;
      }

      if (newIndex !== null) {
        e.preventDefault();
        this.switchTab(this.tabs[newIndex]);
      }
    }
  }

  if (!customElements.get("ayuda-tabs")) {
    customElements.define("ayuda-tabs", AyudaTabs);
  }
</script>
