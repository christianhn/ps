---
import { Image } from "astro:assets";
import { heroData as data } from "../data/hero";
import ofiImg from "../assets/img/ofi-ia.png";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="hero">
  <div class="hero__intro">
    <h1 class="hero__title text-gradient-textured">
      {
        ["Psicología", "adaptada", "a ti."].map((part, i) => (
          <span class={`hero__title-line ${i === 0 ? 'hero__title-break' : ''}`}>
            <span 
              class="hero__title-inner" 
              set:html={part} 
              style={`animation-delay: 0.4s`}
            />
          </span>
        ))
      }
    </h1>
    <div class="hero__bottom">
      <p class="hero__subtitle">{data.subtitle}</p>
      <div class="hero__actions">
        {
          data.actions.map((action) => (
            <a
              href={
                action.href.startsWith("#")
                  ? `${baseUrl}/${action.href}`
                  : action.href
              }
              class={`btn-${action.variant}`}
            >
              {action.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- <div class="hero__visual">
    <div class="hero__card">
      <div class="hero__image-wrapper">
        <Image
          src={ofiImg}
          alt="Consulta de psicología de Mario Catena en Zaragoza"
          class="hero__image"
          loading="eager"
        />
        <div class="hero__overlay"></div>
      </div>
      <div class="hero__caption">
        <div class="hero__caption-bar"></div>
        <p class="hero__caption-text">{data.caption}</p>
      </div>
    </div>
  </div> -->
</section>

<style lang="scss">
  .hero {
    &__intro {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8.75rem 3rem 4.5rem;
      max-width: 80rem;
      margin: 0 auto;

      @media (max-width: 64rem) {
        padding: 4.5rem 1.75rem;
      }
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 1.75rem;
      opacity: 0;
      transform: translateY(1rem);
      animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
      text-align: center;

      @media (max-width: 42.5rem) {
        text-align: left;
      }
    }

    &__title {
      font-family: "Helvetica", "Arial", sans-serif;
      font-size: clamp(3.75rem, 8.5vw, 7.375rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.025em;
      text-align: center;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0 0.23em; /* Optimal space between blocks */

      @extend .text-gradient-textured !optional;
      // Fallback if extend fails
      color: var(--sage);

      @media (max-width: 42.5rem) {
        justify-content: flex-start;
        text-align: left;
        max-width: 59.375rem;
      }
    }

    &__title-line {
      display: inline-block;
      vertical-align: bottom;
      overflow: hidden;
      margin-bottom: -0.15em; /* Adjust for tight leading and descenders */
      padding-bottom: 0.15em; /* Room for descenders (g, p, y) */
    }

    &__title-break {
      flex-basis: 100%;
    }

    &__title-inner {
      display: block;
      transform: translateY(105%);
      opacity: 0;
      animation: slideUpReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      will-change: transform;
    }

    &__bottom {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 3rem;
      margin-top: 2rem;
      opacity: 0;
      transform: translateY(1rem);
      animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;

      @media (max-width: 42.5rem) {
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.75rem;
      }
    }

    &__subtitle {
      font-size: 0.9375rem;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.8;
      max-width: 23.75rem;
    }

    &__actions {
      display: none;
      gap: 0.75rem;
      flex-shrink: 0;

      @media (max-width: 42.5rem) {
        display: flex;
      }
    }

    &__visual {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem 6.25rem;
      opacity: 0;
      animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;

      @media (max-width: 64rem) {
        padding: 0 1.75rem 4.5rem;
      }
    }

    &__card {
      width: 100%;
      height: 68vh;
      min-height: 28.75rem;
      max-height: 42.5rem;
      border-radius: var(--radius-lg);
      overflow: hidden;
      background: #222b20;
      position: relative;
      display: flex;
      align-items: flex-end;
    }

    &__image-wrapper {
      position: absolute;
      inset: 0;
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: left;
      position: absolute;
      inset: 0;
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(26, 25, 22, 0.95) 0%,
        rgba(26, 25, 22, 0.166) 45%
      );
      pointer-events: none;
    }

    &__caption {
      position: relative;
      z-index: 2;
      padding: 2rem 2.5rem;
      display: flex;
      align-items: flex-end;
      gap: 1.125rem;

      @media (max-width: 42.5rem) {
        padding: 1.5rem;
      }
    }

    &__caption-bar {
      width: 0.125rem;
      height: 3.75rem;
      background: rgba(255, 255, 255, 0.3);
      flex-shrink: 0;
    }

    &__caption-text {
      font-size: 0.875rem;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.65;
      max-width: 23.75rem;
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUpReveal {
    from {
      opacity: 0;
      transform: translateY(110%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
