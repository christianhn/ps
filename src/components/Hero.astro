---
import { heroData as data } from "../data/hero";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="hero">
  <div class="hero__intro">
    <div class="hero__top">
      <h1 class="hero__title text-gradient-textured">
        <span class="hero__title-line hero__title-break">
          <span class="hero__title-inner" style="animation-delay: 0.4s"
            >Psicología</span
          >
        </span>
        <span class="hero__title-line">
          <span class="hero__title-inner" style="animation-delay: 0.4s"
            >adaptada</span
          >
        </span>
        <span class="hero__title-line">
          <span
            id="hero-typing"
            class="hero__title-inner typing-target"
            style="animation-delay: 0.4s">a ti.</span
          >
        </span>
      </h1>
      <p class="hero__subtitle">{data.subtitle}</p>
    </div>

    <div class="hero__actions">
      {
        data.actions.map((action) => (
          <a
            href={
              action.href.startsWith("#")
                ? `${baseUrl}/${action.href}`
                : action.href
            }
            class={`btn-${action.variant}`}
          >
            {action.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .hero {
    &__intro {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8.75rem 3rem 4.5rem;
      max-width: 80rem;
      margin: 0 auto;
      will-change: transform, opacity;

      @media (max-width: 42.5rem) {
        padding: 5rem 1.75rem 5rem;
        height: 95vh;
        justify-content: flex-start;
      }
    }

    &__top {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;

      @media (max-width: 42.5rem) {
        align-items: flex-start;
        gap: 1.5rem;
        margin-top: auto; /* Vertically center between top and buttons */
      }
    }

    &__title {
      font-family: "Helvetica", "Arial", sans-serif;
      font-size: clamp(3.75rem, 8.5vw, 7.375rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.025em;
      text-align: center;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0 0.23em;

      @extend .text-gradient-textured !optional;
      color: var(--sage);

      @media (max-width: 42.5rem) {
        justify-content: flex-start;
        text-align: left;
        max-width: 100%;
        margin-bottom: 0;
      }
    }

    &__title-line {
      display: inline-block;
      vertical-align: bottom;
      overflow: hidden;
      margin-bottom: -0.15em;
      padding-bottom: 0.15em;

      @media (max-width: 42.5rem) {
        flex-basis: 100%;
      }
    }

    &__title-break {
      flex-basis: 100%;
    }

    &__title-inner {
      display: block;
      transform: translateY(105%);
      opacity: 0;
      animation: slideUpReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      will-change: transform;

      &.typing-target {
        display: inline-block;
      }
    }

    &__subtitle {
      font-size: 0.9375rem;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.8;
      max-width: 23.75rem;
      text-align: center;
      opacity: 0;
      transform: translateY(1rem);
      animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;

      @media (max-width: 42.5rem) {
        text-align: left;
        max-width: 17.5rem;
      }
    }

    &__actions {
      display: none;
      gap: 0.75rem;
      flex-shrink: 0;
      opacity: 0;
      transform: translateY(1rem);
      animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.75s forwards;

      @media (max-width: 42.5rem) {
        display: flex;
        justify-content: space-between;
        width: 100%;
        margin-top: auto;
        // padding-bottom: calc(3.5rem + env(safe-area-inset-bottom, 0px));

        .btn-dark,
        .btn-ghost {
          letter-spacing: -1px;
          background: transparent;
          border: none;
          padding: 0;
          height: auto;
          font-weight: 700;
          color: var(--ink);
          font-size: 0.9375rem;
          min-width: 0;
          text-decoration: none;
        }
      }
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUpReveal {
    from {
      opacity: 0;
      transform: translateY(110%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  import { initTyping } from "../scripts/typing";

  const setupHeroParallax = () => {
    const intro = document.querySelector(".hero__intro") as HTMLElement;
    if (!intro) return;

    const onScroll = () => {
      const scrollY = window.scrollY;

      if (scrollY > window.innerHeight * 1.5) return;

      const translateY = scrollY * 0.45;
      const opacity = 1 - Math.min(1, scrollY / 600);

      requestAnimationFrame(() => {
        intro.style.transform = `translate3d(0, -${translateY}px, 0)`;
        intro.style.opacity = opacity.toString();
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  };

  // Re-run on page load (support ViewTransitions)
  document.addEventListener("astro:page-load", () => {
    setupHeroParallax();
    initTyping({
      elementId: "hero-typing",
      phrases: ["a ti.", "a tu ritmo.", "a tu vida."],
      waitBeforeStart: 3000,
    });
  });
</script>
