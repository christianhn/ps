---
import { Image } from "astro:assets";
import { servicesData as services } from "../data/services";
---

<section id="servicios" class="services">
  <div class="services__container">
    <header class="services__header reveal">
      <p class="services__eyebrow">Especialidades</p>
      <h2 class="services__title">Servicios <em>especializados.</em></h2>
      <p class="services__subtitle">
        Atención adaptada a tus necesidades a través de diferentes modalidades
        terapéuticas.
      </p>
    </header>

    <services-tabs class="services__tabs">
      <div class="services__layout">
        <!-- Left: list -->
        <ul class="services__list reveal" role="tablist">
          {
            services.map((s, i) => (
              <li
                role="tab"
                aria-selected={i === 0 ? "true" : "false"}
                aria-controls={`service-panel-${i}`}
                class={`services__item ${i === 0 ? "services__item--active" : ""}`}
                tabindex="0"
              >
                {s.title}
              </li>
            ))
          }
        </ul>

        <!-- Center: image -->
        <div class="services__image-col reveal">
          <div class="services__image-wrapper">
            {
              services.map((s, i) => (
                <div
                  class={`services__image-panel ${i === 0 ? "services__image-panel--active" : ""}`}
                  id={`service-img-${i}`}
                  style={`background: ${s.bg}`}
                >
                  <Image
                    src={s.img}
                    alt={s.title}
                    class="services__image"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right: description -->
        <div class="services__content-col reveal">
          {
            services.map((s, i) => (
              <div
                id={`service-panel-${i}`}
                role="tabpanel"
                tabindex="0"
                class={`services__panel ${i === 0 ? "services__panel--active" : ""}`}
              >
                <p class="services__num">
                  {s.num} / {s.title}
                </p>
                <h3 class="services__panel-title">{s.title}.</h3>
                <p class="services__panel-body">{s.body}</p>
                <a
                  href="#contacto"
                  data-service={s.svc}
                  class="text-link services__cta"
                >
                  Reservar sesión →
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </services-tabs>
  </div>
</section>

<style lang="scss">
  .services {
    padding: 6rem 0;

    &__container {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem;
    }

    &__header {
      text-align: center;
      margin-bottom: 4.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    &__eyebrow {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 1rem;
    }

    &__title {
      font-family: inherit;
      font-size: clamp(2.25rem, 4.5vw, 3.75rem);
      font-weight: 400;
      letter-spacing: -0.015em;
      color: var(--ink);
      line-height: 1.1;

      em {
        font-style: italic;
        color: var(--sage);
      }
    }

    &__subtitle {
      font-size: 0.9375rem;
      font-weight: 300;
      color: var(--ink-mid);
      margin-top: 1rem;
      line-height: 1.7;
      max-width: 31.25rem;
    }

    &__layout {
      display: grid;
      grid-template-columns: 12rem 1fr 25rem;
      gap: 4rem;
      align-items: start;

      @media (max-width: 75rem) {
        gap: 3rem;
        grid-template-columns: 12.5rem 1fr 17.25rem;
      }

      @media (max-width: 64rem) {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
    }

    &__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;

      @media (max-width: 64rem) {
        flex-direction: row;
        overflow-x: auto;
        padding: 0 1rem 1rem;
        margin: 0 -1rem;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;

        // Horizontal scroll indicator (fade)
        mask-image: linear-gradient(
          to right,
          transparent,
          black 5%,
          black 90%,
          transparent 100%
        );
        -webkit-mask-image: linear-gradient(
          to right,
          transparent,
          black 5%,
          black 90%,
          transparent 100%
        );

        &::-webkit-scrollbar {
          display: none;
        }
      }
    }

    &__item {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-light);
      padding: 0.75rem 0;
      border-bottom: 0.5px solid var(--pill-border);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      transition: all 0.25s ease;

      &::before {
        content: "";
        width: 0.3125rem;
        height: 0.3125rem;
        border-radius: 50%;
        background: transparent;
        flex-shrink: 0;
        transition: background 0.25s ease;
      }

      &:hover:not(&--active) {
        color: var(--ink-mid);
      }

      &--active {
        color: var(--ink);
        font-weight: 400;
        border-color: var(--ink);

        &::before {
          background: var(--sage);
        }
      }

      @media (max-width: 64rem) {
        border: 0.5px solid var(--pill-border);
        border-radius: 3.125rem;
        padding: 0.625rem 1.25rem;
        white-space: nowrap;

        &::before {
          display: none;
        }

        &--active {
          background: var(--ink);
          color: var(--white);
          border-color: var(--ink);
        }
      }
    }

    &__image-wrapper {
      border-radius: var(--radius-card);
      overflow: hidden;
      aspect-ratio: 4 / 5;
      position: relative;
      width: 100%;
      background: var(--cream-mid);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);

      @media (max-width: 64rem) {
        aspect-ratio: 16/11;
      }
    }

    &__image-panel {
      display: none;
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;

      &--active {
        display: flex;
        position: relative;
      }
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.94;
    }

    &__panel {
      display: none;
      animation: fadeIn 0.4s ease-out;

      &--active {
        display: block;
      }
    }

    &__num {
      font-size: 0.6875rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 1.25rem;
    }

    &__panel-title {
      font-family: inherit;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 400;
      letter-spacing: -0.015em;
      color: var(--ink);
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }

    &__panel-body {
      font-size: 0.875rem;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.8;
    }

    &__cta {
      margin-top: 2rem;
      display: inline-flex;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  class ServicesTabs extends HTMLElement {
    connectedCallback() {
      const tabs = this.querySelectorAll(".services__item");
      const panels = this.querySelectorAll(".services__panel");
      const images = this.querySelectorAll(".services__image-panel");

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => {
            t.classList.remove("services__item--active");
            t.setAttribute("aria-selected", "false");
          });
          panels.forEach((p) => p.classList.remove("services__panel--active"));
          images.forEach((img) =>
            img.classList.remove("services__image-panel--active"),
          );

          tab.classList.add("services__item--active");
          tab.setAttribute("aria-selected", "true");
          panels[index].classList.add("services__panel--active");
          images[index].classList.add("services__image-panel--active");
        });

        tab.addEventListener("keydown", (e: any) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            (tab as HTMLElement).click();
          }
        });
      });
    }
  }

  if (!customElements.get("services-tabs")) {
    customElements.define("services-tabs", ServicesTabs);
  }
</script>
