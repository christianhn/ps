---
import { tarifasData as data } from "../data/tarifas";
---

<section id="tarifas" class="tarifas">
  <div class="tarifas__container">
    <header class="tarifas__header reveal">
      <h2 class="tarifas__title">{data.header.title}</h2>
      <p class="tarifas__subtitle">{data.header.subtitle}</p>
    </header>

    <div class="tarifas__grid">
      {
        data.plans.map((plan) => (
          <div
            class={`tarifa-card ${plan.featured ? "tarifa-card--featured" : ""} reveal`}
          >
            <div class="tarifa-card__type">{plan.tipo}</div>
            <h3 class="tarifa-card__name">{plan.nombre}</h3>
            <div class="tarifa-card__price">
              <span class="tarifa-card__currency">€</span>
              <span class="tarifa-card__amount">{plan.precio}</span>
            </div>
            <p class="tarifa-card__duration">{plan.duracion}</p>
            <hr class="tarifa-card__divider" />
            <ul class="tarifa-card__features">
              {plan.features.map((feature) => (
                <li class="tarifa-card__feature">
                  <strong>{feature.label}:</strong> {feature.price} (
                  {feature.saving})
                </li>
              ))}
            </ul>
            <a
              href="#contacto"
              data-service={plan.service}
              class="tarifa-card__button"
            >
              Reservar sesión
            </a>
          </div>
        ))
      }
    </div>

    <div class="tarifas__conditions reveal reveal-delay-2">
      <h3 class="tarifas__conditions-title">{data.condiciones.title}</h3>
      <ul class="tarifas__conditions-list">
        {
          data.condiciones.list.map((condicion) => (
            <li class="tarifas__conditions-item">{condicion}</li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .tarifas {
    background: var(--cream);
    padding: 6rem 0;

    &__container {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 3rem;
    }

    &__header {
      margin-bottom: 3.5rem;
      padding-bottom: 2.5rem;
      border-bottom: 0.5px solid var(--pill-border);
    }

    &__title {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      font-size: clamp(2.25rem, 4vw, 3.375rem);
      font-weight: 400;
      letter-spacing: -0.015em;
      color: var(--ink);
    }

    &__subtitle {
      font-size: 0.875rem;
      color: var(--ink-mid);
      font-weight: 300;
      max-width: 17.5rem;
      line-height: 1.7;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    &__conditions {
      margin-top: 3.5rem;
      padding: 2.5rem;
      background: var(--white);
      border-radius: 1.25rem;
      border: 0.5px solid var(--pill-border);
      max-width: 50rem;
      margin-inline: auto;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);

      &-title {
        font-family: "Helvetica", "Arial", sans-serif;
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--ink);
        margin-bottom: 1.25rem;
      }

      &-list {
        list-style: none;
        padding: 0;
      }

      &-item {
        font-size: 0.875rem;
        color: var(--ink-mid);
        font-weight: 300;
        line-height: 1.6;
        position: relative;
        padding-left: 1.125rem;
        margin-bottom: 0.75rem;

        &:last-child {
          margin-bottom: 0;
        }

        &::before {
          content: "·";
          position: absolute;
          left: 0;
          color: var(--ink-light);
        }
      }
    }
  }

  .tarifa-card {
    background: var(--white);
    border-radius: 1.25rem;
    padding: 2.25rem 2rem;
    border: 0.5px solid var(--pill-border);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s ease;

    &:hover {
      transform: translateY(-0.25rem);
      box-shadow: 0 1.25rem 3rem rgba(26, 25, 22, 0.07);
    }

    &--featured {
      background: var(--ink);
      border-color: var(--ink);

      .tarifa-card__type {
        color: var(--white-45);
      }

      .tarifa-card__name,
      .tarifa-card__price {
        color: var(--white);
      }

      .tarifa-card__duration {
        color: var(--white-45);
      }

      .tarifa-card__divider {
        border-color: var(--white-12);
      }

      .tarifa-card__features .tarifa-card__feature {
        color: var(--white-60);

        &::before {
          background: var(--sage-light);
        }
      }

      .tarifa-card__button {
        background: var(--white);
        color: var(--ink);
        border-color: var(--white);

        &:hover {
          opacity: 0.88;
        }
      }
    }

    &__type {
      font-size: 0.75rem;
      color: var(--ink-light);
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    &__name {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      font-size: 1.375rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 1.25rem;
      line-height: 1.2;
    }

    &__price {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      font-size: 3.25rem;
      font-weight: 400;
      color: var(--ink);
      letter-spacing: -0.02em;
      line-height: 1;
      display: flex;
      align-items: flex-start;
      gap: 0.25rem;
    }

    &__currency {
      font-size: 1.375rem;
      padding-top: 0.5rem;
    }

    &__duration {
      font-size: 0.8125rem;
      color: var(--ink-light);
      font-weight: 300;
      margin: 0.625rem 0 1.5rem;
    }

    &__divider {
      border: none;
      border-top: 0.5px solid var(--pill-border);
      margin: 0 0 1.5rem;
    }

    &__features {
      list-style: none;
      padding: 0;
      margin-bottom: 1.75rem;
    }

    &__feature {
      font-size: 0.8125rem;
      font-weight: 300;
      color: var(--ink-mid);
      padding: 0.5rem 0;
      display: flex;
      gap: 0.625rem;
      align-items: flex-start;

      &::before {
        content: "";
        width: 0.3125rem;
        height: 0.3125rem;
        border-radius: 50%;
        background: var(--sage);
        flex-shrink: 0;
        margin-top: 0.375rem;
      }
    }

    &__button {
      display: block;
      width: 100%;
      padding: 0.8125rem;
      border-radius: 3.125rem;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: "Helvetica", "Arial", sans-serif;
      border: 0.5px solid var(--pill-border);
      background: var(--white);
      color: var(--ink);
      transition: all 0.2s ease;
      text-align: center;
      text-decoration: none;

      &:hover {
        background: var(--ink);
        color: var(--white);
        border-color: var(--ink);
      }
    }
  }

  @media (max-width: 64rem) {
    .tarifas {
      &__container {
        padding: 0 1.5rem;
      }

      &__grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      &__conditions {
        padding: 1.5rem;
      }
    }
  }
</style>
